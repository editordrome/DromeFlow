# ==========================================
# .geminiignore para DromeFlow
# Otimização de Tokens no Google Antigravity
# ==========================================

# 1. Dependências e Builds (Mais pesados)
node_modules/
dist/
build/
.vite/
.next/
out/

# 2. Arquivos de Sistema do macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# 3. Assets Visuais e Binários (A IA não lê imagens)
public/assets/**/*.png
public/assets/**/*.jpg
public/assets/**/*.jpeg
public/assets/**/*.svg
public/assets/**/*.ico
public/assets/**/*.webp
*.gif
*.mp4

# 4. Arquivos de Dados Brutos (Evitar ler planilhas de upload da MB Londrina, etc.)
*.xlsx
*.xls
*.csv
*.pdf
# Se houver diretório temporário de upload local:
uploads/
tmp/

# 5. Variáveis de Ambiente e Segredos (Segurança)
.env
.env.*
.env.local
*.pem
*.key

# 6. Logs e Caches Locais
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache
.prettiercache

# 7. Configurações de IDE e Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?