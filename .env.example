# DromeFlow - Environment Variables Template
# Copie este arquivo para .env.local e preencha com suas credenciais reais

# ====================
# Supabase - Projeto DromeFlow
# ====================
# Obtenha estas credenciais em: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-publica-aqui

# ====================
# Notas Importantes
# ====================
# 1. NUNCA commite o arquivo .env.local (já está no .gitignore)
# 2. Use apenas chaves ANÔNIMAS públicas (nunca service_role ou secret)
# 3. As variáveis devem começar com VITE_ para serem expostas no frontend
# 17. Após criar .env.local, reinicie o servidor de desenvolvimento (npm run dev)

# ====================
# SFTP (SSH) - Deploy Automático
# ====================
# Estas credenciais são usadas pelo comando 'npm run deploy' (porta SSH Hostinger)
# SFTP_PASSWORD deve ser colocada apenas no .env.local
SFTP_HOST=72.61.220.147
SFTP_PORT=65002
SFTP_USER=u854441981
SFTP_DEST=public_html
SFTP_PASSWORD=sua-senha-aqui
